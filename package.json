{
  "name": "@chukyolink/auth",
  "version": "1.3.0",
  "description": "中京大学の認証システムを利用するためのパッケージ",
  "keywords": [
    "auth",
    "shibboleth",
    "chukyo-university",
    "chukyolink"
  ],
  "homepage": "https://chukyolink.github.io/chukyolink-auth",
  "bugs": {
    "url": "https://github.com/chukyolink/chukyolink-auth/issues"
  },
  "license": "AGPL-3.0-only",
  "author": {
    "name": "KATO Hayate",
    "email": "dev@hayatek.jp",
    "url": "https://hayatek.jp/"
  },
  "files": [
    "./dist/*"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "repository": "github:chukyolink/chukyolink-auth",
  "scripts": {
    "build": "tsup",
    "build:docs": "typedoc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "fetch-cookie": "^3.2.0",
    "node-html-parser": "^7.1.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.13.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.0.0 <27.0.0",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  }
}
